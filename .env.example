# ═══════════════════════════════════════════════════════════════
#  CarCare Tracker — Variables de entorno
#  Copiá este archivo a .env y completá los valores reales.
#  NUNCA subas el .env real al repositorio.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# BACKEND — Spring Boot (Railway)
# ───────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Obtenelo en: Atlas → Connect → Drivers → Java
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret para firmar tokens (cualquier cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Google OAuth Client ID (para validar tokens de Google en el backend)
# Obtenelo en: console.cloud.google.com → APIs → Credenciales → OAuth 2.0
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ── Alertas por email (Gmail) ──────────────────────────────────
# REQUERIDO para que las alertas de mantenimiento funcionen.
#
# Pasos para obtener GMAIL_APP_PASSWORD:
#   1. Activá verificación en 2 pasos en tu cuenta Google
#   2. Ir a: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
#   3. Crear contraseña para "Correo / Windows/Mac" → copiá los 16 caracteres
#
# GMAIL_USER  = la cuenta Gmail desde la que se envían las alertas
# GMAIL_APP_PASSWORD = la contraseña de aplicación de 16 caracteres (SIN espacios)

GMAIL_USER=tuempresa@gmail.com
GMAIL_APP_PASSWORD=abcdabcdabcdabcd

# ───────────────────────────────────────────────────────────────
# FRONTEND — Next.js (Railway o Vercel)
# ───────────────────────────────────────────────────────────────

# URL base del backend (sin barra final)
NEXT_PUBLIC_API_URL=https://tu-backend.up.railway.app

# Google OAuth Client ID (mismo valor que el backend, usado en el botón "Sign in with Google")
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
